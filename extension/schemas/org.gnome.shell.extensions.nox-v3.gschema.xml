<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.nox-v3" path="/org/gnome/shell/extensions/nox-v3/">
    <key name="nox-scale-percent" type="i">
      <default>100</default>
      <range min="20" max="200"/>
      <summary>Size</summary>
      <description>Nox V3 visual and body size percentage.</description>
    </key>
    <key name="movement-profile" type="s">
      <default>'balanced'</default>
      <choices>
        <choice value="calm"/>
        <choice value="balanced"/>
        <choice value="snappy"/>
        <choice value="smooth"/>
      </choices>
      <summary>Movement Profile</summary>
      <description>Preset for walking speed and walking animation cadence.</description>
    </key>
    <key name="walking-speed-percent" type="i">
      <default>100</default>
      <range min="40" max="160"/>
      <summary>Walking Speed</summary>
      <description>Fine walking speed percentage applied to the selected movement profile.</description>
    </key>
    <key name="run-length-ticks" type="i">
      <default>14</default>
      <range min="7" max="56"/>
      <summary>Run Length</summary>
      <description>Click-triggered run duration in V3 update ticks.</description>
    </key>
    <key name="run-speed-percent" type="i">
      <default>100</default>
      <range min="40" max="220"/>
      <summary>Run Speed</summary>
      <description>Click-triggered run speed percentage, relative to the default V3 run speed.</description>
    </key>
    <key name="gravity-profile" type="s">
      <default>'earth'</default>
      <choices>
        <choice value="earth"/>
        <choice value="moon"/>
      </choices>
      <summary>Gravity Profile</summary>
      <description>Preset fall strength: Earth-like or Moon-like.</description>
    </key>
    <key name="websocket-url" type="s">
      <default>''</default>
      <summary>WebSocket URL</summary>
    </key>
    <key name="token" type="s">
      <default>''</default>
      <summary>Desktop token</summary>
    </key>
    <key name="cert-fingerprint" type="s">
      <default>''</default>
      <summary>Certificate SHA256 fingerprint</summary>
    </key>
    <key name="connection-state" type="s">
      <default>'not-started'</default>
      <summary>Last connection state</summary>
    </key>
    <key name="manual-disconnected" type="b">
      <default>false</default>
      <summary>Pause background connection</summary>
    </key>
  </schema>
</schemalist>
