<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.nox-v3" path="/org/gnome/shell/extensions/nox-v3/">
    <key name="gravity-profile" type="s">
      <default>'earth'</default>
      <choices>
        <choice value="earth"/>
        <choice value="moon"/>
      </choices>
      <summary>Gravity Profile</summary>
      <description>Preset fall strength: Earth-like or Moon-like.</description>
    </key>
    <key name="jump-reach-distance" type="i">
      <default>280</default>
      <range min="80" max="900"/>
      <summary>Jump Reach</summary>
      <description>Maximum distance in pixels for upward jump target scanning.</description>
    </key>
    <key name="websocket-url" type="s">
      <default>''</default>
      <summary>WebSocket URL</summary>
    </key>
    <key name="token" type="s">
      <default>''</default>
      <summary>Desktop token</summary>
    </key>
    <key name="cert-fingerprint" type="s">
      <default>''</default>
      <summary>Certificate SHA256 fingerprint</summary>
    </key>
    <key name="connection-state" type="s">
      <default>'not-started'</default>
      <summary>Last connection state</summary>
    </key>
    <key name="manual-disconnected" type="b">
      <default>false</default>
      <summary>Pause background connection</summary>
    </key>
    <key name="jump-command-seq" type="i">
      <default>0</default>
      <summary>Manual jump command sequence</summary>
    </key>
    <key name="jump-command-result" type="s">
      <default>'Not tried'</default>
      <summary>Manual V1 jump command result</summary>
    </key>
    <key name="generated-jump-command-seq" type="i">
      <default>0</default>
      <summary>Manual generated jump command sequence</summary>
    </key>
    <key name="generated-jump-command-result" type="s">
      <default>'Not tried'</default>
      <summary>Manual generated jump command result</summary>
    </key>
    <key name="jetpack-jump-command-seq" type="i">
      <default>0</default>
      <summary>Manual jetpack jump command sequence</summary>
    </key>
    <key name="jetpack-jump-command-result" type="s">
      <default>'Not tried'</default>
      <summary>Manual jetpack jump command result</summary>
    </key>
    <key name="rest-command-seq" type="i">
      <default>0</default>
      <summary>Manual rest command sequence</summary>
    </key>
    <key name="rest-command-result" type="s">
      <default>'Not tried'</default>
      <summary>Manual rest command result</summary>
    </key>
  </schema>
</schemalist>
